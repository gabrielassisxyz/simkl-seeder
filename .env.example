# Simkl credentials. Copy to `.env` (gitignored) and fill in.
#
# client_id / API key: create an app in Simkl Developer settings
#   (https://simkl.com/settings/developer). The redirect URI is unused by this
#   project — put http://localhost:5173/ if the form requires a value.
SIMKL_CLIENT_ID=

# Per-user OAuth access token. Obtain ONCE via the PIN flow:
#   SIMKL_CLIENT_ID=... ./scripts/simkl-login.sh
# then paste the printed token here. Required for writes (watch-later, watched).
SIMKL_ACCESS_TOKEN=

# API base host. The docs live at api.simkl.org; the callable API has historically
# been api.simkl.com. Confirm with the first request and change here if needed.
SIMKL_API_BASE=https://api.simkl.com
